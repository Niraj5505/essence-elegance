<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Orders - Essence Elegance</title>
    <link rel="stylesheet" href="styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body class="light-theme">
    <header class="site-header">
        <a href="index.html" class="logo">ESSENCE ELEGANCE</a>
        <nav>
            <a href="register.html">Register</a>
            <a href="login.html">Login</a>
            <a href="shop.html">Shop</a>
            <div class="dropdown">
                <a href="cart.html">Cart <i class="fas fa-chevron-down"></i></a>
            </div>
            <div class="dropdown">
                <a href="#">My account <i class="fas fa-chevron-down"></i></a>
                <div class="dropdown-content">
                    <a href="reset-password.html">Password Reset</a>
                    <a href="account.html">Account</a>
                    <a href="#">Privacy Policy</a>
                </div>
            </div>
            <a href="orders.html" class="active">Orders</a>
            <a href="#" class="search-icon"><i class="fas fa-search"></i></a>
        </nav>
    </header>

    <main class="orders-container">
        <!-- Perfume Effect Background -->
        <div class="perfume-mist-container" id="perfume-effect">
            <div class="spray-nozzle" id="nozzle"></div>
            <div class="mist-cloud" style="top: 10%; left: 10%; width: 300px; height: 300px;"></div>
            <div class="mist-cloud" style="top: 50%; right: 10%; width: 400px; height: 400px; animation-delay: -5s;">
            </div>
            <div class="mist-cloud" style="bottom: 10%; left: 20%; width: 350px; height: 350px; animation-delay: -10s;">
            </div>
        </div>
        <h1>My Orders</h1>

        <!-- No Orders Message -->
        <div id="no-orders-message" class="cart-empty-message" style="display: none;">
            <i class="fas fa-box-open"></i>
            <p>You haven't placed any orders yet.</p>
            <a href="shop.html" class="btn-return-shop">START SHOPPING</a>
        </div>

        <!-- Orders List -->
        <div id="orders-list" class="orders-list">
            <!-- Orders injected by JS -->
            <div class="loading-spinner">
                <i class="fas fa-circle-notch fa-spin"></i> Loading your orders...
            </div>
        </div>
    </main>

    <footer class="site-footer">
        <div class="footer-content">
            <p class="design-credit">Design By PERFUME MALL PVT.LTD</p>
        </div>
    </footer>

    <script type="module" src="auth-check.js"></script>
    <script type="module" src="orders.js"></script>
    <script src="luxury-effects.js"></script>
</body>

</html>